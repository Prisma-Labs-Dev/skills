{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "package.json",
      "catalog/**",
      "docs/**",
      "schemas/**",
      "scripts/**",
      "skills/**/*.md",
      "sources/**",
      "src/**",
      "tests/**",
      "README.md",
      "AGENTS.md",
      ".env.example",
      ".claude-plugin/**",
      "tsconfig.json",
      "vitest.config.ts"
    ]
  }
}
